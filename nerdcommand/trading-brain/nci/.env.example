# NCI Live Update — environment variables
# Copy to .env and fill in your values. Never commit .env to git.

# --- Backend toggle ---
USE_LOCAL_LLAMA=false          # set true after llama-cpp wheels installed

# --- Ollama ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5-coder:7b
OLLAMA_KEEP_ALIVE=60m
OLLAMA_TIMEOUT=60

# --- Direct llama-cpp ---
LOCAL_MODEL_PATH=D:\NERDCOMMANDCLAUDEBRAIN\models\qwen2.5-coder-7b-instruct-q4_k_m.gguf
LOCAL_GPU_LAYERS=35            # lower if VRAM is tight (e.g. 20 for 8GB card)
LOCAL_CTX_SIZE=4096
LOCAL_THREADS=6

# --- MT4 EA live files (NCI_GodMode_v3_2_Fusion.mq4 writes here) ---
# Portable mode default: <MT4_INSTALL>\MFiles\
# Standard install:      %APPDATA%\MetaQuotes\Terminal\<INSTANCE_ID>\MFiles\
MT4_FILES_DIR=D:\NERDCOMMANDCLAUDEBRAIN\mt4_files
BRIDGE_POLL_SEC=2

# --- Legacy bridge snapshots (if using separate bridge process) ---
BRIDGE_DATA_DIR=D:\NERDCOMMANDCLAUDEBRAIN\bridge

# --- Alpha Vantage FX Live Feed ---
# Get your free API key at: https://www.alphavantage.co/support/#api-key
# Free tier: 25 requests/day  → use --once mode or AV_CACHE_MINUTES=60
# Premium:   75 requests/min  → watch mode with AV_CACHE_MINUTES=1
AV_API_KEY=YOUR_KEY_HERE
AV_INTERVAL=5min               # candle interval: 1min/5min/15min/30min/60min
AV_CACHE_MINUTES=5             # cache TTL (increase to 60+ on free tier)
AV_OUTPUTSIZE=compact          # compact=100 bars, full=all history
AV_PAIRS=EUR/USD,GBP/USD,USD/JPY,USD/CHF,AUD/USD
# AV_MODE: "supplement" = use AV when MT4 is offline | "live" = always use AV
AV_MODE=supplement

# --- Output ---
SIGNAL_LOG_DIR=D:\NERDCOMMANDCLAUDEBRAIN\signals
ANALYSIS_DIR=D:\NERDCOMMANDCLAUDEBRAIN\analysis
